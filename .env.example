# ── PostgreSQL ───────────────────────────────────────────────────────────
# Single source of truth for the DB. These do two jobs:
#   1. The Postgres container reads them on first boot and creates the
#      DB + user (official image behavior).
#   2. The app derives DATABASE_URL from them in code:
#        postgresql+psycopg://{POSTGRES_USER}:{POSTGRES_PASSWORD}@{POSTGRES_HOST}:{POSTGRES_PORT}/{POSTGRES_DB}
#      Change a value here once — both sides follow. No separate DATABASE_URL.
POSTGRES_USER=pocsearch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pocsearch
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Model gateway (OpenAI-compatible, ModelHarbor) ──────────────────────
# One base URL + one key serve all three model kinds; code appends the path:
#   LLM:    $LLM_ENDPOINT/v1/chat/completions       (modernize step — the one retained LLM call)
#   embed:  $EMBEDDING_ENDPOINT/v1/embeddings        (BGE-M3 query + doc embeddings)
#   rerank: $RERANK_ENDPOINT/v1/rerank              (config only — NOT wired into /search yet)
EMBEDDING_ENDPOINT=
LLM_ENDPOINT=
RERANK_ENDPOINT=
MODEL_API_KEY=             # Bearer token the gateway requires on every call

# Model IDs (case-sensitive on this gateway — uppercase BAAI/ is rejected).
# Embedder stays bge-m3 (1024-d) to match the existing documents.embedding vector(1024)
# column: no schema migration, no re-embed of ~745k rows. qwen/qwen3-embedding-4b
# (2560-d) is also served here if you accept a vector(1024)→vector(2560) migration
# + full re-embed. LLM is a thinking model — budget max_tokens for reasoning.
LLM_MODEL=Qwen/Qwen3.6-35B-A3B
EMBED_MODEL=baai/bge-m3
RERANK_MODEL=jina_ai/jina-reranker-v3

# ── Frontend (Next.js) ───────────────────────────────────────────────────
# NEXT_PUBLIC_* is baked into the client bundle at BUILD time. The value is a same-origin
# path; next.config.mjs `rewrites` proxies /api/* → http://backend:8000/* over the docker
# network (the browser can't resolve the `backend` hostname directly).
NEXT_PUBLIC_API_URL=/api
